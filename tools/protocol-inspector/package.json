{
  "name": "@cemp/protocol-inspector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Offline decoder for CEMP message/profile cells, envelopes, contact bundles and vault files (ckb_testnet).",
  "scripts": {
    "inspect": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cemp/ckb": "workspace:*",
    "@cemp/core": "workspace:*",
    "@cemp/crypto": "workspace:*",
    "@cemp/secure-vault": "workspace:*"
  }
}
